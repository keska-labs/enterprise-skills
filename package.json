{
  "name": "agent-skill-sync",
  "displayName": "Agent Skill Sync",
  "description": "Curate agent skills from GitHub or custom registries—progressive browse, cached catalog, one-click sync into .cursor/rules.",
  "version": "0.1.1",
  "publisher": "open-source",
  "license": "MIT",
  "keywords": [
    "cursor",
    "skills",
    "github",
    "sync",
    "agent",
    "rules",
    "ai"
  ],
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:skillSync.sidebarManager",
    "onCommand:skillSync.manageSkills",
    "onCommand:skillSync.focusSidebar",
    "onCommand:skillSync.configureSource",
    "onCommand:skillSync.syncNow"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillSync",
          "title": "Skills",
          "icon": "media/skill-sync.svg"
        }
      ]
    },
    "views": {
      "skillSync": [
        {
          "id": "skillSync.sidebarManager",
          "name": "Skill Manager",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "skillSync.manageSkills",
        "title": "Skill Sync: Manage AI Skills"
      },
      {
        "command": "skillSync.configureSource",
        "title": "Skill Sync: Configure Source"
      },
      {
        "command": "skillSync.syncNow",
        "title": "Skill Sync: Sync Now"
      },
      {
        "command": "skillSync.focusSidebar",
        "title": "Skill Sync: Focus Sidebar"
      }
    ],
    "keybindings": [
      {
        "command": "skillSync.focusSidebar",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
    "configuration": {
      "title": "Agent Skill Sync",
      "properties": {
        "skillSync.sourceMode": {
          "type": "string",
          "enum": [
            "github-repo",
            "custom-registry"
          ],
          "default": "github-repo"
        },
        "skillSync.sourceRepository": {
          "type": "string",
          "default": ""
        },
        "skillSync.registryUrl": {
          "type": "string",
          "default": ""
        },
        "skillSync.categories": {
          "type": "array",
          "default": [
            "Security",
            "Infrastructure",
            "Workflow",
            "Documentation"
          ]
        },
        "skillSync.optedInSkills": {
          "type": "array",
          "default": []
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist coverage .tsbuildinfo",
    "compile:tests": "tsc -p ./tsconfig.json --outDir dist-test",
    "compile": "webpack --mode development",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src webview-ui --ext .ts,.tsx",
    "test": "jest --coverage",
    "test:extension": "npm run compile:tests && node ./dist-test/src/test/runExtensionTests.js",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run clean && npm run lint && npm run test && npm run build"
  },
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-electron": "^2.5.2",
    "ajv": "^8.20.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
