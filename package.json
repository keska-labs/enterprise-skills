{
  "name": "agent-skill-sync",
  "displayName": "Agent Skill Sync",
  "description": "Curate agent skills from private GitHub repositories and custom registries—progressive browse, cached catalog, one-click sync into .cursor/rules.",
  "version": "0.8.0",
  "publisher": "KeskaLabsAB",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/sponsors/keska-labs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keska-labs/enterprise-skills"
  },
  "bugs": {
    "url": "https://github.com/keska-labs/enterprise-skills/issues"
  },
  "keywords": [
    "cursor",
    "skills",
    "github",
    "sync",
    "agent",
    "rules",
    "ai"
  ],
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillSync",
          "title": "Skills",
          "icon": "media/skill-sync.svg"
        }
      ]
    },
    "views": {
      "skillSync": [
        {
          "id": "skillSync.sidebarManager",
          "name": "Skill Manager",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "skillSync.manageSkills",
        "title": "Skill Sync: Manage AI Skills"
      },
      {
        "command": "skillSync.configureSource",
        "title": "Skill Sync: Add Skill Source"
      },
      {
        "command": "skillSync.removeSource",
        "title": "Skill Sync: Remove Skill Source"
      },
      {
        "command": "skillSync.syncNow",
        "title": "Skill Sync: Sync Now"
      },
      {
        "command": "skillSync.signIn",
        "title": "Skill Sync: Sign In to GitHub"
      },
      {
        "command": "skillSync.focusSidebar",
        "title": "Skill Sync: Focus Sidebar"
      },
      {
        "command": "skillSync.setOpenAiRecommendationKey",
        "title": "Skill Sync: Set OpenAI API Key (Recommendations)"
      },
      {
        "command": "skillSync.setAnthropicRecommendationKey",
        "title": "Skill Sync: Set Anthropic API Key (Recommendations)"
      },
      {
        "command": "skillSync.setCursorSdkRecommendationKey",
        "title": "Skill Sync: Set Cursor API Key (Recommendations)"
      },
      {
        "command": "skillSync.clearRecommendationKeys",
        "title": "Skill Sync: Clear Recommendation API Keys"
      }
    ],
    "keybindings": [
      {
        "command": "skillSync.focusSidebar",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ],
    "configuration": {
      "title": "Agent Skill Sync",
      "properties": {
        "skillSync.sources": {
          "type": "array",
          "default": [],
          "description": "Ordered list of skill sources. Each source is fetched independently and merged into the workspace catalog. Cursor rules and skill packages are written under namespaced folders (`.cursor/rules/<label>/`, `.cursor/skills/<label>/`).",
          "items": {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["github-repo", "custom-registry", "official-skills", "open-skills"],
                "description": "Source kind: GitHub (`owner/repo`), custom HTTPS registry, or discovery-only directories (officialskills.sh / skills.sh)."
              },
              "value": {
                "type": "string",
                "description": "GitHub `owner/repo` or registry base URL."
              },
              "label": {
                "type": "string",
                "description": "Optional short label used as the workspace folder prefix and as the source badge in the UI. Auto-derived when omitted (repo segment for GitHub, hostname for registries)."
              }
            }
          }
        },
        "skillSync.sourceMode": {
          "type": "string",
          "enum": [
            "github-repo",
            "custom-registry"
          ],
          "default": "github-repo",
          "deprecationMessage": "Deprecated. Use `skillSync.sources` instead. Read-only fallback for one release while the extension auto-migrates existing workspaces."
        },
        "skillSync.sourceRepository": {
          "type": "string",
          "default": "",
          "deprecationMessage": "Deprecated. Use `skillSync.sources` instead."
        },
        "skillSync.registryUrl": {
          "type": "string",
          "default": "",
          "deprecationMessage": "Deprecated. Use `skillSync.sources` instead."
        },
        "skillSync.categories": {
          "type": "array",
          "default": [
            "Security",
            "Infrastructure",
            "Workflow",
            "Documentation"
          ]
        },
        "skillSync.optedInSkills": {
          "type": "array",
          "default": []
        },
        "skillSync.recommendations.useLanguageModel": {
          "type": "boolean",
          "default": true,
          "description": "Try LLM providers for the Recommended tab before falling back to keyword heuristics."
        },
        "skillSync.recommendations.modelFamily": {
          "type": "string",
          "default": "gpt-4o",
          "description": "vscode.lm chat model family filter (VS Code + Copilot)."
        },
        "skillSync.recommendations.cacheTtlMinutes": {
          "type": "number",
          "default": 1440,
          "minimum": 1,
          "description": "How long to cache AI/heuristic recommendation results per workspace."
        },
        "skillSync.recommendations.cursorSdkModel": {
          "type": "string",
          "default": "composer-2",
          "description": "Model id when using @cursor/sdk with a Cursor API key."
        },
        "skillSync.recommendations.openAiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI model id for BYOK recommendations."
        },
        "skillSync.recommendations.anthropicModel": {
          "type": "string",
          "default": "claude-3-5-haiku-20241022",
          "description": "Anthropic model id for BYOK recommendations."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist coverage .tsbuildinfo",
    "compile:tests": "tsc -p ./tsconfig.json --outDir dist-test",
    "compile": "webpack --mode development",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src webview-ui --ext .ts,.tsx",
    "test": "jest --coverage",
    "test:extension": "npm run compile:tests && node ./dist-test/src/test/runExtensionTests.js",
    "test:watch": "jest --watch",
    "check:release": "npm run clean && npm run lint && npm run test && npm run build",
    "vscode:prepublish": "npm run check:release",
    "prepublishOnly": "npm run check:release",
    "vsix": "npx vsce package",
    "verify:icon": "bash scripts/verify-marketplace-icon.sh"
  },
  "type": "commonjs",
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "axios": "^1.15.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "ajv": "^8.20.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}