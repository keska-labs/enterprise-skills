{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Play Agent Skill Sync",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build",
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      }
    }
  ]
}
